{
  "name": "resize-video-desktop",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "build": {
    "appId": "com.resizevideo.desktop",
    "productName": "Resize Video Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor",
        "to": "vendor"
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": ["x64"]
        }
      ]
    }
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "server": "tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"const fs=require('fs');try{fs.rmSync('dist',{recursive:true,force:true})}catch(e){}\"",
    "desktop:dev": "node scripts/desktop/dev.js",
    "desktop:build": "node scripts/desktop/build.js",
    "desktop:healthcheck": "node scripts/desktop/healthcheck.js",
    "desktop:verify-vendor-payload": "node scripts/desktop/verifyVendorPayload.js",
    "desktop:doctor": "node scripts/desktop/doctor.js",
    "desktop:smoke": "tsx scripts/desktop/smoke.ts",
    "desktop:assert-no-renderer-secrets": "node scripts/desktop/assertNoRendererSecrets.js",
    "desktop:auth-smoke": "tsx scripts/desktop/authSmoke.ts",
    "desktop:probe-nvenc": "node scripts/desktop/probeNvenc.js",
    "desktop:test-first-run": "tsx scripts/desktop/testFirstRun.ts",
    "desktop:test-recovery": "tsx scripts/desktop/testRecovery.ts",
    "desktop:package": "tsx scripts/desktop/package.ts",
    "desktop:smoke-packaged": "tsx scripts/desktop/smokePackaged.ts",
    "desktop:smoke-render": "tsx scripts/desktop/smokeRender.ts",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.2",
    "form-data": "^4.0.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
